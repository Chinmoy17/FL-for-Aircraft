# uv / Python venv & local secrets
.venv/
.env

# Python build / cache
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.eggs/

# Tests / coverage / type checkers
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# Notebooks
.ipynb_checkpoints/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Heavy training artefacts (CSV logs and PNG plots under results/ ARE tracked,
# per the project brief: "Upload all code (including result logs) to a GitHub repository").
checkpoints/
*.pth
*.pt
*.ckpt
*.npz
*.npy
*.log

# Node.js / Vite / TS build artefacts (frontend/). Listed here at repo root so
# every branch inherits the rule, regardless of whether frontend/ exists yet.
# Before this rule landed, branching from a branch without frontend/.gitignore
# meant `git add -A` would slurp the entire node_modules tree (~50 MB).
node_modules/
dist/
dist-ssr/
.vite/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


deployment.txt